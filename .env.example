# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# At least one provider key is required. Guardian routes to the cheapest
# capable model from whichever providers you configure here.
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-06-01
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
OLLAMA_API_BASE=http://localhost:11434
MISTRAL_API_KEY=
COHERE_API_KEY=

# ── Guardian Admin ─────────────────────────────────────────────────────────────
# GUARDIAN_API_KEY: single admin key used by the dashboard login.
# ADMIN_API_KEYS:   comma-separated list to bootstrap multiple admin keys on
#                   first start (e.g. for CI or multi-operator setups).
# SECRET_KEY:       internal signing secret — use a random 32+ char string.
GUARDIAN_API_KEY=change-me-in-production
ADMIN_API_KEYS=
SECRET_KEY=change-me-32-chars-minimum

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite is fine for development and light production use.
# Switch to PostgreSQL for multi-worker deployments.
DATABASE_URL=sqlite+aiosqlite:///./guardian.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/guardian

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development         # development | staging | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# CORS: comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Response Cache ─────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
# Semantic caching uses embeddings to match near-duplicate prompts.
# Guardian stores recent embeddings in Redis and falls back to in-memory similarity matching.
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95   # cosine similarity — raise to be more strict
EMBEDDING_MODEL=text-embedding-ada-002

# ── Routing ────────────────────────────────────────────────────────────────────
# Number of recent requests to keep in the p95 latency rolling window.
LATENCY_WINDOW_SIZE=100

# ── Guardrails & Budgets ────────────────────────────────────────────────────────
# Hard per-request cost cap (returns 402 if exceeded).
MAX_REQUEST_COST_USD=1.0
# Requests above this threshold require X-Guardian-Confirm-Expensive: 1 (returns 409).
EXPENSIVE_MODEL_THRESHOLD_USD=0.10
# Daily and monthly cumulative spend caps (returns 402 when hit).
DAILY_BUDGET_USD=10.0
MONTHLY_BUDGET_USD=100.0

# ── Pricing & Analytics ────────────────────────────────────────────────────────
# Model used as the savings baseline (savings = baseline_cost - actual_cost).
BASELINE_MODEL=gpt-4o
# Optional: URL to a remote pricing catalog JSON. Leave blank to use built-ins.
PRICING_CATALOG_URL=
