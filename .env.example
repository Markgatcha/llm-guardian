# ── LLM Provider Keys ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
GROQ_API_KEY=...

# ── Guardian API ─────────────────────────────────────────────────────────────
GUARDIAN_API_KEY=change-me-in-production
SECRET_KEY=change-me-32-chars-minimum

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./guardian.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/guardian

# ── Redis Stack ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Cache TTL (seconds) ───────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
