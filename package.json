{
  "name": "llm-guardian",
  "version": "1.0.0",
  "description": "Central Nervous System of the AI Trio — zero-config, sub-30ms token optimization with Semantic Folding & VCM Sharding",
  "type": "module",
  "main": "src/core/orchestrator.ts",
  "module": "src/core/orchestrator.ts",
  "types": "src/core/types.ts",
  "bin": {
    "guardian": "src/cli/index.ts"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "config.example.yaml"
  ],
  "scripts": {
    "start": "bun run src/cli/index.ts --start",
    "dashboard": "bun run src/cli/index.ts --dash",
    "optimize": "bun run src/cli/index.ts --optimize",
    "dev": "bun --watch src/cli/index.ts --start",
    "test": "bun test",
    "lint": "bunx biome check src/",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.6.0",
    "nanoid": "^5.0.9",
    "openai": "^4.70.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@biomejs/cli-win32-x64": "^2.4.10",
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.0"
  }
}
