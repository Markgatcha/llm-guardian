{
  "name": "llm-guardian",
  "version": "1.6.26",
  "description": "LLM token optimization gateway — Semantic Folding, VCM Sharding, prompt caching, tool gating. 80-95% prompt compression with sub-30ms overhead.",
  "type": "module",
  "main": "src/core/orchestrator.ts",
  "module": "src/core/orchestrator.ts",
  "types": "src/core/types.ts",
  "bin": {
    "guardian": "dist/guardian.js"
  },
  "exports": {
    ".": {
      "types": "src/core/types.ts",
      "import": "src/core/orchestrator.ts"
    },
    "./folding": {
      "types": "src/core/folding-engine.ts",
      "import": "src/core/folding-engine.ts"
    },
    "./sharding": {
      "types": "src/core/vcm-sharder.ts",
      "import": "src/core/vcm-sharder.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "config.example.yaml"
  ],
  "sideEffects": false,
  "keywords": [
    "llm",
    "token-optimization",
    "prompt-compression",
    "semantic-folding",
    "vcm-sharding",
    "ai-gateway",
    "openai-proxy",
    "cost-optimization",
    "prompt-caching",
    "context-engineering",
    "anthropic",
    "openrouter",
    "guardrails",
    "token-reduction",
    "context-window",
    "bun",
    "agent-framework",
    "tool-gating",
    "ai-trio",
    "budget-management"
  ],
  "author": "Markgatcha",
  "license": "MIT",
  "homepage": "https://github.com/Markgatcha/llm-guardian#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/llm-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/Markgatcha/llm-guardian/issues"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts start server",
    "dashboard": "bun run src/cli/index.ts dash",
    "tui": "bun run src/cli/index.ts",
    "optimize": "bun run src/cli/index.ts optimize",
    "dev": "bun --watch src/cli/index.ts start server",
    "build": "bun build src/cli/index.ts --target bun --outdir dist --entry-naming guardian.js && bash scripts/trim-wasm.sh",
    "bench": "bun run scripts/bench-v1626-modules.ts",
    "test": "bun test",
    "lint": "bunx biome check src/",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "nanoid": "^5.1.9",
    "openai": "^4.104.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@biomejs/cli-linux-x64": "2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3"
  }
}
